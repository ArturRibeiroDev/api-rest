{
  "compilerOptions": {
    "target": "ES2023",                                  
     "lib": ["ES2023"],  
     "types": ["node"],
     
    /* Modules */
    "module": "nodenext",                                
    "esModuleInterop": true,                             
    "forceConsistentCasingInFileNames": true, 

    /* Type Checking */
    "strict": true,         
    "skipLibCheck": true     
  }
}
